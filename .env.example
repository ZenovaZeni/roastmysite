# ============================================================================
# RoastMySite — Environment Variables
# ============================================================================
# Copy this file to .env.local for local development, OR paste each value
# into Vercel's project settings → Environment Variables when deploying.
#
# All keys here are FREE-TIER signups. Total recurring cost: $0/mo for
# infrastructure, $0.24/mo for the domain. See DEPLOY.md for sign-up links.
# ============================================================================


# --- AI ROASTER (provider rotation: Groq → Gemini → template fallback) ----

# Groq — primary AI roast (Llama 4 Scout vision, 1,000 req/day free)
# Sign up: https://console.groq.com/keys
GROQ_API_KEY=

# Gemini — fallback when Groq is rate-limited (Gemini 2.5 Flash-Lite, 1,000 req/day free)
# Sign up: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=


# --- LIGHTHOUSE (real Core Web Vitals + Perf/A11y/SEO scores) -------------

# Google PageSpeed Insights API — free with key, 25,000 req/day
# Sign up: https://console.cloud.google.com (enable PageSpeed Insights API)
PSI_API_KEY=


# --- OPTIONAL TUNING ------------------------------------------------------

# Set to "1" to skip the local Lighthouse path entirely (forces PSI).
# Already auto-skipped on Vercel (because VERCEL env var is set there).
# Useful if you want to test the production code path locally.
DISABLE_LOCAL_LIGHTHOUSE=

# Set to "1" to skip the local Ollama Gemma path entirely.
# Already auto-skipped on Vercel. Useful for forcing remote-provider testing locally.
DISABLE_LOCAL_GEMMA=

# If you're running your own local Ollama with a non-default port:
# OLLAMA_URL=http://localhost:11434
# LOCAL_MODEL=gemma4:latest
